# DocuNative Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains your API keys.

# Cohere API — get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Backend switcher — true = use Ollama locally (no API cost)
USE_OLLAMA=false

# Ollama config (only needed if USE_OLLAMA=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Dataset writer (dataset.builder.writer) — max parallel LLM calls
# Cohere default is 8 if unset; Ollama default is 1 (single local queue/GPU).
# Override with: python -m dataset.builder.writer --workers N
WRITER_MAX_WORKERS=

# Eval 2 QA factory (dataset.builder.qa_factory_llm) — max parallel Cohere chats
# Default is 1 if unset (trial tiers often 429 with 2+ concurrent requests). Set 4–8 only if
# your Cohere plan allows it. CLI: --workers N
# If Cohere returns 429 immediately: --workers 1 or unset this variable
QA_FACTORY_LLM_MAX_WORKERS=

# Seconds to sleep before *each* Cohere chat attempt (each doc may try up to MAX_RETRIES+1 times).
# Trial tiers: try 3–6 to space bursts. Default 0.
# QA_FACTORY_LLM_MIN_DELAY_SEC=

# Cohere 429 backoff (writer + qa_factory_llm; trial keys are often ~20 calls/min)
# COHERE_429_MAX_RETRIES=10
# COHERE_429_INITIAL_DELAY_SEC=10
# COHERE_429_MAX_DELAY_SEC=120

# On HTTP 429, log API response body + headers (Retry-After, rate limits). Set to 0 to hide.
# COHERE_LOG_429_DETAILS=1

# Gradio port (optional — default 7860)
# GRADIO_PORT=7860
