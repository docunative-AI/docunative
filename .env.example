# DocuNative Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains your API keys.

# Cohere API — get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Backend switcher — true = use Ollama locally (no API cost)
USE_OLLAMA=false

# Ollama config (only needed if USE_OLLAMA=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Dataset writer (dataset.builder.writer) — max parallel LLM calls
# Cohere default is 8 if unset; Ollama default is 1 (single local queue/GPU).
# Override with: python -m dataset.builder.writer --workers N
WRITER_MAX_WORKERS=

# Cohere 429 backoff (dataset.builder.writer — trial keys are often 20 calls/min)
# COHERE_429_MAX_RETRIES=10
# COHERE_429_INITIAL_DELAY_SEC=10
# COHERE_429_MAX_DELAY_SEC=120

# Gradio port (optional — default 7860)
# GRADIO_PORT=7860
