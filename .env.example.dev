# Cohere API (production). Get key from https://dashboard.cohere.com/
COHERE_API_KEY=your_key_here

# Use Ollama for local testing (no API cost). Set to true to use local model.
USE_OLLAMA=false

# Ollama model name (e.g. gemma2:9b, qwen2.5:14b). Only used when USE_OLLAMA=true.
OLLAMA_MODEL=gemma2:9b

# Ollama server URL. Only used when USE_OLLAMA=true.
OLLAMA_BASE_URL=http://localhost:11434
